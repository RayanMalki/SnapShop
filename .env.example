# Copie ce fichier vers .env À LA RACINE du repo : cp .env.example .env
# (le backend lit le .env de la racine, PAS celui de backend/)

HOST=0.0.0.0
PORT=8000

# OBLIGATOIRE : clé Gemini (https://aistudio.google.com/apikey)
# Sans elle, la vision tourne en mode mock (toujours le même t-shirt bleu).
GEMINI_API_KEY=

# LAISSER VIDE. Le client UCP utilise alors un profil d'agent public qui marche.
# Mettre une URL inexistante ici casse la recherche UCP (profile_malformed).
UCP_AGENT_PROFILE_URL=

DATABASE_URL=sqlite:///./data/snapshop.db
